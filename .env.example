# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Discord ───────────────────────────────────────────────────────────────────
# Bot token — Discord Developer Portal > Your App > Bot > Reset Token
DISCORD_TOKEN=your_discord_bot_token_here

# Legacy fallback channel IDs (multi-channel routing is in bot/job_search_keywords.py)
DISCORD_CHANNEL_ID=your_channel_id
DISCORD_CHANNEL_ID2=your_channel_id2

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
POSTGRES_URL=postgresql://user:password@localhost:5432/upwork_jobs

# ── Upwork (optional) ─────────────────────────────────────────────────────────
# Only needed if using authenticated scraping (not required for visitor API)
UPWORK_EMAIL=your_upwork_email@example.com
UPWORK_PASSWORD=your_upwork_password

# 2Captcha API key — https://2captcha.com (optional, for CAPTCHA solving)
TWO_CAPTCHA_API_KEY=your_2captcha_key

# ── AI Filtering — Module 2 (coming soon) ─────────────────────────────────────
# Google Gemini API — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
