# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Discord ───────────────────────────────────────────────────────────────────
# Bot token — Discord Developer Portal > Your App > Bot > Reset Token
DISCORD_TOKEN=your_discord_bot_token_here

# Legacy fallback channel IDs (multi-channel routing is in bot/job_search_keywords.py)
DISCORD_CHANNEL_ID=your_channel_id
DISCORD_CHANNEL_ID2=your_channel_id2

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
POSTGRES_URL=postgresql://user:password@localhost:5432/upwork_jobs

# ── Upwork (optional) ─────────────────────────────────────────────────────────
# Only needed if using authenticated scraping (not required for visitor API)
UPWORK_EMAIL=your_upwork_email@example.com
UPWORK_PASSWORD=your_upwork_password

# 2Captcha API key — https://2captcha.com (optional, for CAPTCHA solving)
TWO_CAPTCHA_API_KEY=your_2captcha_key

# ── Upwork Visitor Auth (rotate these when you get 401 / no results) ──────────
# How to get fresh values:
#   1. Open Chrome → upwork.com/nx/search/jobs/?q=developer (while logged in)
#   2. Open DevTools → Network tab → filter "graphql"
#   3. Click any visitorJobSearch request → Headers tab
#   4. Copy "Authorization: Bearer oauth2v2_..." → UPWORK_OAUTH_TOKEN (without "Bearer ")
#   5. Copy "Vnd-Eo-Visitorid" header value → UPWORK_VISITOR_ID
#   6. Update these two values, restart the bot — no code change needed
UPWORK_OAUTH_TOKEN=oauth2v2_your_token_here
UPWORK_VISITOR_ID=your_visitor_id_here

# ── AI Filtering — Module 2 (coming soon) ─────────────────────────────────────
# Google Gemini API — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# ── MERIDIAN Discord notifications ────────────────────────────────────────────
# Channel ID for #meridian-alerts on the same server as job channels.
# Receives: MERIDIAN match/skip verdicts, cycle cost reports, proposal drafts.
# Set to 0 (or remove) to disable Discord notifications.
MERIDIAN_DISCORD_CHANNEL_ID=your_meridian_alerts_channel_id
